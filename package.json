{
  "name": "@andbc/pigment",
  "version": "0.0.3",
  "publishConfig": {
    "access": "public"
  },
  "description": "A CLI tool to convert colors between different formats (HEX, RGB, HSL, etc.)",
  "type": "module",
  "bin": "dist/index.js",
  "files": [
    "dist"
  ],
  "main": "index.js",
  "scripts": {
    "build": "tsc --noemit && tsup ./src/index.ts --format esm",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "author": "Andy Duboc",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.0.8",
    "@types/yargs": "^17.0.35",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@texel/color": "^1.1.11",
    "yargs": "17.7.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andydbc/pigment.git"
  }
}
